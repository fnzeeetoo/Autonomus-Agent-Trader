# Polygon RPC endpoint
POLYGON_RPC_URL=https://polygon-rpc.com

# Wallet private key (hex, with or without 0x prefix)
WALLET_PRIVATE_KEY=your_private_key_here

# Discord webhooks
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_DAILY=https://discord.com/api/webhooks/...

# Telegram bot token and chat ID (for OpenClaw heartbeat)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Data source path (CSV or SQLite)
DATA_SOURCE=./data/market_data.csv
